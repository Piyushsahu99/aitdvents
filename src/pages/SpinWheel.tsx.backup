import { useState, useRef } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Badge } from "@/components/ui/badge";
import { useToast } from "@/hooks/use-toast";
import { useNavigate } from "react-router-dom";
import { Trophy, Plus, X, Sparkles, ArrowLeft, RotateCw, Download } from "lucide-react";
import confetti from "canvas-confetti";
import { ConfettiEffect } from "@/components/quiz/ConfettiEffect";

interface WheelItem {
  id: number;
  label: string;
  color: string;
}

const defaultColors = [
  "#ef4444", "#f59e0b", "#10b981", "#8b5cf6",
  "#3b82f6", "#ec4899", "#06b6d4", "#f97316",
  "#84cc16", "#a855f7", "#14b8a6", "#f43f5e"
];

export default function SpinWheel() {
  const { toast } = useToast();
  const navigate = useNavigate();
  const [spinning, setSpinning] = useState(false);
  const [rotation, setRotation] = useState(0);
  const [totalWinnings, setTotalWinnings] = useState(0);
  const [spinsLeft, setSpinsLeft] = useState(3);
  const [lastPrize, setLastPrize] = useState<Prize | null>(null);
  const wheelRef = useRef<HTMLDivElement>(null);

  const spin = () => {
    if (spinning || spinsLeft === 0) return;

    setSpinning(true);
    setSpinsLeft(prev => prev - 1);

    // Random prize selection
    const prizeIndex = Math.floor(Math.random() * prizes.length);
    const prize = prizes[prizeIndex];
    
    // Calculate rotation (multiple full spins + landing position)
    const segmentAngle = 360 / prizes.length;
    const targetAngle = 360 - (prizeIndex * segmentAngle + segmentAngle / 2);
    const spins = 5; // Number of full rotations
    const finalRotation = rotation + (360 * spins) + targetAngle;

    setRotation(finalRotation);

    // After spin animation
    setTimeout(() => {
      setSpinning(false);
      setLastPrize(prize);
      setTotalWinnings(prev => prev + prize.coins);

      // Celebration effect
      confetti({
        particleCount: 150,
        spread: 100,
        origin: { y: 0.6 },
        colors: [prize.color, '#fbbf24', '#ffffff'],
      });

      toast({
        title: `You Won ${prize.coins} Coins! ${prize.icon}`,
        description: spinsLeft - 1 > 0 ? `${spinsLeft - 1} spins remaining` : "No spins left",
      });
    }, 4000);
  };

  const reset = () => {
    setSpinsLeft(3);
    setTotalWinnings(0);
    setLastPrize(null);
    setRotation(0);
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900 p-4">
      <div className="container mx-auto max-w-5xl py-8">
        {/* Header */}
        <div className="text-center mb-8 animate-in fade-in slide-in-from-top duration-700">
          <div className="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-6 py-3 rounded-full mb-4">
            <Sparkles className="h-5 w-5 text-yellow-400 animate-pulse" />
            <span className="text-white font-bold">Lucky Spin Wheel</span>
            <Sparkles className="h-5 w-5 text-yellow-400 animate-pulse" />
          </div>
          <h1 className="text-5xl md:text-6xl font-bold text-white mb-2 drop-shadow-2xl">
            SPIN TO WIN!
          </h1>
          <p className="text-xl text-white/80">Test your luck and win AITD Coins</p>
        </div>

        <div className="grid lg:grid-cols-3 gap-6">
          {/* Stats Sidebar */}
          <div className="space-y-4 animate-in fade-in slide-in-from-left duration-700">
            <Card className="bg-white/10 backdrop-blur-md border-white/20">
              <CardContent className="p-6">
                <div className="flex items-center gap-3 mb-4">
                  <Zap className="h-8 w-8 text-yellow-400" />
                  <div>
                    <div className="text-white/60 text-sm">Spins Left</div>
                    <div className="text-4xl font-bold text-white">{spinsLeft}</div>
                  </div>
                </div>
                <div className="grid grid-cols-3 gap-2">
                  {[...Array(3)].map((_, i) => (
                    <div
                      key={i}
                      className={`h-3 rounded-full transition-all duration-300 ${
                        i < spinsLeft
                          ? "bg-gradient-to-r from-yellow-400 to-orange-500 shadow-lg shadow-yellow-500/50"
                          : "bg-white/20"
                      }`}
                    />
                  ))}
                </div>
              </CardContent>
            </Card>

            <Card className="bg-white/10 backdrop-blur-md border-white/20">
              <CardContent className="p-6">
                <div className="flex items-center gap-3">
                  <Trophy className="h-8 w-8 text-yellow-400" />
                  <div>
                    <div className="text-white/60 text-sm">Total Winnings</div>
                    <div className="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-orange-500">
                      {totalWinnings}
                    </div>
                  </div>
                </div>
              </CardContent>
            </Card>

            {lastPrize && (
              <Card className="bg-gradient-to-br from-yellow-500/20 to-orange-500/20 backdrop-blur-md border-yellow-400/50 animate-in fade-in zoom-in duration-500">
                <CardContent className="p-6 text-center">
                  <div className="text-5xl mb-2">{lastPrize.icon}</div>
                  <div className="text-white font-bold text-lg">Last Win</div>
                  <div className="text-3xl font-bold text-yellow-400">
                    {lastPrize.coins}
                  </div>
                  <div className="text-white/60 text-sm">coins</div>
                </CardContent>
              </Card>
            )}

            {spinsLeft === 0 && (
              <Card className="bg-gradient-to-br from-green-500/20 to-emerald-500/20 backdrop-blur-md border-green-400/50 animate-in fade-in slide-in-from-bottom duration-500">
                <CardContent className="p-6 text-center">
                  <Crown className="h-12 w-12 mx-auto text-yellow-400 mb-3 animate-bounce" />
                  <div className="text-white font-bold text-xl mb-2">
                    Game Complete!
                  </div>
                  <div className="text-white/80 text-sm mb-4">
                    You earned {totalWinnings} AITD Coins
                  </div>
                  <Button
                    onClick={reset}
                    className="w-full bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-600 hover:to-emerald-600"
                  >
                    <Gift className="h-4 w-4 mr-2" />
                    Play Again
                  </Button>
                </CardContent>
              </Card>
            )}
          </div>

          {/* Wheel */}
          <div className="lg:col-span-2 animate-in fade-in zoom-in duration-700">
            <Card className="bg-white/10 backdrop-blur-md border-white/20 overflow-hidden">
              <CardContent className="p-8 relative">
                {/* Pointer */}
                <div className="absolute top-4 left-1/2 -translate-x-1/2 z-20">
                  <div className="w-0 h-0 border-l-[20px] border-l-transparent border-r-[20px] border-r-transparent border-t-[40px] border-t-red-500 drop-shadow-2xl animate-bounce" />
                </div>

                {/* Wheel Container */}
                <div className="relative w-full max-w-lg mx-auto aspect-square">
                  {/* Outer Glow */}
                  <div className="absolute inset-0 rounded-full bg-gradient-to-r from-yellow-400 via-orange-500 to-red-500 blur-3xl opacity-50 animate-pulse" />
                  
                  {/* Wheel */}
                  <div
                    ref={wheelRef}
                    className="relative w-full h-full rounded-full shadow-2xl transition-transform ease-out"
                    style={{
                      transform: `rotate(${rotation}deg)`,
                      transitionDuration: '4000ms',
                      transitionTimingFunction: spinning ? 'cubic-bezier(0.17, 0.67, 0.12, 0.99)' : 'ease-out',
                    }}
                  >
                    {/* Center Circle */}
                    <div className="absolute inset-0 rounded-full border-8 border-white/30" />
                    
                    {/* Segments */}
                    {prizes.map((prize, index) => {
                      const angle = (360 / prizes.length) * index;
                      return (
                        <div
                          key={prize.id}
                          className="absolute w-full h-full"
                          style={{
                            transform: `rotate(${angle}deg)`,
                          }}
                        >
                          <div
                            className="absolute left-1/2 top-0 w-1/2 h-1/2 origin-bottom-left"
                            style={{
                              backgroundColor: prize.color,
                              clipPath: `polygon(0 0, 100% 0, 50% 100%)`,
                              transform: `rotate(${360 / prizes.length}deg)`,
                            }}
                          >
                            <div
                              className="absolute top-[25%] left-[60%] -translate-x-1/2 text-center"
                              style={{
                                transform: `rotate(${-(angle + 360 / prizes.length / 2)}deg)`,
                              }}
                            >
                              <div className="text-2xl mb-1 drop-shadow-lg">{prize.icon}</div>
                              <div className="text-white font-bold text-xs drop-shadow-lg whitespace-nowrap">
                                {prize.label}
                              </div>
                            </div>
                          </div>
                        </div>
                      );
                    })}

                    {/* Center Button */}
                    <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                      <div className="w-24 h-24 rounded-full bg-gradient-to-br from-yellow-400 to-orange-500 shadow-2xl flex items-center justify-center border-4 border-white">
                        <Star className="h-12 w-12 text-white animate-spin-slow" />
                      </div>
                    </div>
                  </div>
                </div>

                {/* Spin Button */}
                <div className="mt-8 text-center">
                  <Button
                    onClick={spin}
                    disabled={spinning || spinsLeft === 0}
                    size="lg"
                    className="bg-gradient-to-r from-yellow-400 via-orange-500 to-red-500 hover:from-yellow-500 hover:via-orange-600 hover:to-red-600 text-white font-bold text-xl px-12 py-6 rounded-full shadow-2xl disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-300 hover:scale-105 active:scale-95"
                  >
                    {spinning ? (
                      <span className="flex items-center gap-2">
                        <Zap className="h-6 w-6 animate-pulse" />
                        SPINNING...
                      </span>
                    ) : spinsLeft === 0 ? (
                      "No Spins Left"
                    ) : (
                      <span className="flex items-center gap-2">
                        <Sparkles className="h-6 w-6" />
                        SPIN NOW
                        <Sparkles className="h-6 w-6" />
                      </span>
                    )}
                  </Button>
                </div>
              </CardContent>
            </Card>

            {/* Prize Table */}
            <Card className="mt-4 bg-white/10 backdrop-blur-md border-white/20">
              <CardContent className="p-6">
                <h3 className="text-white font-bold text-lg mb-4 flex items-center gap-2">
                  <Gift className="h-5 w-5 text-yellow-400" />
                  Prize Pool
                </h3>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                  {prizes.map((prize) => (
                    <div
                      key={prize.id}
                      className="flex items-center gap-2 bg-white/5 p-3 rounded-lg hover:bg-white/10 transition-colors"
                    >
                      <div className="text-2xl">{prize.icon}</div>
                      <div>
                        <div className="text-white font-bold">{prize.coins}</div>
                        <div className="text-white/60 text-xs">coins</div>
                      </div>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          </div>
        </div>

        {/* Back Button */}
        <div className="mt-8 text-center">
          <Button
            variant="outline"
            onClick={() => navigate("/games")}
            className="bg-white/10 hover:bg-white/20 text-white border-white/30"
          >
            ← Back to Games
          </Button>
        </div>
      </div>
    </div>
  );
}
